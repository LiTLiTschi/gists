# Copy this file to .env and fill in your values.
# All values are optional — scripts will prompt for anything that's missing.

# ── mymuma backend ────────────────────────────────────────────────────────────
# Path to marimo/backend/duckdb.py in your mymuma checkout.
# Used by: rename_migrator.py, populate_db.py
MYMUMA_BACKEND=~/projects/mymuma/marimo/backend/duckdb.py

# DuckDB database file
# Used by: rename_migrator.py, populate_db.py
MYMUMA_DB=/mnt/ssd/music/mymuma.duckdb

# ── Audio directories ─────────────────────────────────────────────────────────
# Used by: rename_migrator.py, hq_to_mp3.py
MYMUMA_MP3_DIR=/mnt/ssd/music/scdl/mp3
MYMUMA_HQ_MP3_DIR=/mnt/ssd/music/scdl/hq-mp3
MYMUMA_HQ_DIR=/mnt/ssd/music/scdl/hq

# ── SoundCloud credentials ────────────────────────────────────────────────────
# Used by: sc_download.py, populate_db.py
SC_CLIENT_ID=
SC_AUTH_TOKEN=

# ── SoundCloud download output ────────────────────────────────────────────────
# Used by: sc_download.py
SC_OUTPUT_DIR=~/Music/SoundCloud

# ── HQ → MP3 conversion ───────────────────────────────────────────────────────
# Used by: hq_to_mp3.py
# HQ_TO_MP3_SRC=
# HQ_TO_MP3_DEST=
FFMPEG_PATH=ffmpeg

# ── Metadata transfer ─────────────────────────────────────────────────────────
# Used by: transfer_metadata.py
# TRANSFER_META_SRC=
# TRANSFER_META_TGT=
